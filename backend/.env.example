# The Odds API - https://the-odds-api.com/ (免費 500 次/月)
ODDS_API_KEY=your_api_key_here

# API-Football - https://www.api-football.com/ (免費 100 次/天，足球陣容/傷病/戰術)
# 用於世界盃與五大聯盟分析，未設定時僅用賠率+比分
API_FOOTBALL_KEY=

# 足球分析門檻（世界盃 / 五大聯盟）
FOOTBALL_MIN_EV=0.03
# 足球角球備選（主盤膠著時優先生效；逐場 event-odds，極耗額度，需明確 true 才開啟）
FOOTBALL_ENABLE_CORNERS=false
FOOTBALL_MAX_CORNERS_GAMES=6
FOOTBALL_CORNERS_MARKET_BLEND=0.55
FOOTBALL_CORNERS_MIN_EDGE=2.0
FOOTBALL_ENABLE_PROPS=false
# API-Football 免費方案約 10 次/分鐘；預設每次請求間隔 1.2 秒
# API_FOOTBALL_MIN_GAP_MS=1200
# 足球球員盤為逐場 event-odds，極耗免費額度；需明確 true 才開啟
# FOOTBALL_MAX_PROP_GAMES=4
FOOTBALL_MAX_PROP_GAMES=8

# 籃球初盤（NBA / WNBA / 夏季聯賽）— 效率×節奏 + 常態淨勝分
BASKETBALL_MIN_EV=0.03
BASKETBALL_HOME_COURT_PTS=3.0
BASKETBALL_MARGIN_SIGMA=11.5
BASKETBALL_TOTAL_SIGMA=14

# 足球 Dixon–Coles ρ（負值提高平局相關）
FOOTBALL_DC_RHO=-0.08

# 網球初盤（動態發現 active ATP/WTA）
TENNIS_MIN_EV=0.03
TENNIS_AVG_GAMES_BO3=22.5
TENNIS_AVG_GAMES_BO5=38
TENNIS_SPREAD_SCALE=4.5
TENNIS_TOTALS_SCALE=3.5

# 伺服器
PORT=3101
# 模型版本（每次公式/權重改動必須遞增，供歷史快照比較）
MODEL_VERSION=baseball-v2.9.1
# 過信：>72% 不得主推／均注；−1.5 均注蓋盤≥70%；獨贏均注≥64%
PRIMARY_MAX_MODEL_PROB=0.72
FLAT_BET_MAX_MODEL_PROB=0.72
FLAT_BET_MINUS15_MIN_COVER=0.70
FLAT_BET_MIN_PROB_H2H=0.64
RELIABILITY_MIN_SLICE_SAMPLES=50
# NPB baseball-data.com 隊級 OPS/WHIP（預設開；回測對照可設 false）
ENABLE_NPB_BASEBALL_DATA_FORM=true
NPB_ROLLING_LEAGUE_OPS=0.670
NPB_ROLLING_LEAGUE_WHIP=1.22
# KBO 官網 eng.koreabaseball.com 隊級 OPS/WHIP（預設開）
ENABLE_KBO_OFFICIAL_FORM=true
KBO_ROLLING_LEAGUE_OPS=0.745
KBO_ROLLING_LEAGUE_WHIP=1.46
# KBO 當日先發（官網賽程+投手頁 ERA/WHIP → 調 λ；王牌日會拉開讓分期望）
ENABLE_KBO_PITCHERS=true
KBO_PITCHER_SUPPRESSION_SCALE=0.65
ASIAN_STAFF_WHIP_WHEN_PITCHER=0.4

# MLB 明星打者缺陣加權（實驗；預設關。回測用當日 boxscore）
ENABLE_STAR_IMPACT=false
STAR_IMPACT_MAX_PENALTY=0.04
# NPB 勝率優先：貼市 + 嚴門檻
# 獨贏膠著時優先大小（55/45 或熱門<58%）
H2H_AMBIGUOUS_MAX_GAP=0.10
H2H_AMBIGUOUS_MAX_FAV=0.58
H2H_CLEAR_FAV_PROB=0.62
H2H_CLEAR_MIN_EDGE_PCT=6
TOTALS_AMBIGUOUS_BOOST=6
MAX_FLAT_BETS_PER_GAME=1
H2H_MARKET_BLEND_NPB_FULL=0.52
H2H_MIN_FAV_NPB=0.56
H2H_MIN_EDGE_PCT_NPB=3.0
FLAT_BET_MIN_PROB_NPB=0.60
FLAT_BET_MIN_EDGE_PCT_NPB=3.5
PREMATCH_MIN_ODDS=1.75
PREMATCH_PRIMARY_MIN_PROB=0.58
FLAT_BET_ALLOW_NPB_TOTALS=true
PREMATCH_PRIMARY_MIN_ODDS=1.75
SPREADS_BLOCK_PLUS15_NO_SCORE=true
# 開賽後仍無任何比分的場次，超過此時數自動視為取消/延期並 void
SETTLEMENT_VOID_AFTER_HOURS=72

# 推薦門檻
MIN_EV_THRESHOLD=0.03
MIN_CONFIDENCE=0.55
MAX_PARLAY_LEGS=20
PARLAY_LOTTERY_MAX_LEGS=0
PARLAY_LOTTERY_MIN_PROB=0.48
PARLAY_LOTTERY_MAX_LEG_ODDS=2.25
FLAT_BET_USD=10
BASE_STAKE_UNIT=10
STAKE_CURRENCY_LABEL=元
STAKE_MIN_MULTIPLIER=0.3
STAKE_MAX_MULTIPLIER=2
STAKE_MIN_AMOUNT=3
STAKE_MAX_AMOUNT=20
STAKE_ROUND_STEP=1
PARLAY_ANCHOR_STAKE_RATIO=0.35
PARLAY_BET_USD=1

# 舊版通用同步 cron（目前不作為 MLB 賽前快照排程）
SYNC_CRON=0 8,14,20 * * *
# MLB 賽前資料快照：後端啟動時自動註冊；前端重新載入不會觸發外部 API
PREMATCH_SCHEDULER_ENABLED=true
PREMATCH_SNAPSHOT_TIMEZONE=Asia/Taipei
PREMATCH_FIXED_SNAPSHOT_HOURS=1,3,5,13,15,17
PREMATCH_WINDOW_CHECK_CRON=*/5 * * * *
PREMATCH_SNAPSHOT_WINDOWS_MINUTES=1440,360,180,90,30,5
PREMATCH_SCHEDULER_GRACE_MINUTES=12
# 已開賽仍保留推薦的滾球窗口（小時）
LIVE_GAME_GRACE_HOURS=6
# 滾球 v1.3（命中率優先：開局凍結 + 對齊初盤）
LIVE_MIN_EV=0.045
LIVE_H2H_MIN_EDGE=4.5
LIVE_TOTALS_MIN_EDGE=5.5
LIVE_UNDER_MIN_EDGE=6.5
LIVE_MAX_MODEL_EDGE=0.045
LIVE_ENABLE_TOTALS=true
LIVE_MIN_INNINGS_PLAYED=3.0
LIVE_ZERO_ZERO_MIN_INNING=4.0
LIVE_TIED_H2H_MIN_INNING=5
LIVE_EARLY_UNDER_MIN_GAP=1.25
LIVE_H2H_MIN_PROB=0.60
LIVE_RESPECT_PREMATCH=true
MAX_LIVE_PICKS_PER_GAME=1
LIVE_STRONG_PROB=0.65
LIVE_MAX_MARKET_GAP=0.12
LIVE_CLOSE_HOME_BOOST=0.055
LIVE_STAKE_HAIRCUT=0.7
LIVE_MAX_STAKE=8
# 滾球避開鎖死熱門：低於此賠率不推；低於 primary 門檻不得主推
LIVE_MIN_ODDS=1.55
LIVE_PRIMARY_MIN_ODDS=1.70
LIVE_LOW_ODDS_EXTRA_EV=0.04
# 滾球面板自動刷新間隔（分鐘）；按鈕會走輕量同步（比分+賠率+滾球分析）
LIVE_POLL_MINUTES=5
# 初盤分析向前看多少小時（48=約2天；7天=168）
UPCOMING_GAME_HORIZON_HOURS=48
# 按日 Slate 預設顯示天數
SLATE_DEFAULT_DAYS=2
# 「同步並分析」要跑的運動（省額度可只留 baseball）
# SLATE_REFRESH_SPORTS=baseball
SLATE_REFRESH_SPORTS=baseball,football,basketball,tennis
# 推薦時區（香港）
DISPLAY_TIMEZONE=Asia/Hong_Kong

# 嚴格門檻無候選時仍選最佳盤口標「樣本」（累積回測；不進均注）
PREMATCH_SAMPLE_FALLBACK=true
# SAMPLE_MIN_EV=0.03
RECOMMEND_PRIMARY_SCORE=65
RECOMMEND_WATCH_SCORE=50
MAX_PICKS_PER_GAME=3
MAX_FLAT_BETS_PER_GAME=1

# 球員盤口（MLB，每場消耗 API 額度）
ENABLE_PLAYER_PROPS=false
MAX_PROP_GAMES=6

# 串關每腿最低賠率
MIN_PARLAY_LEG_ODDS=1.4
MAX_MODEL_EDGE_PCT=0.06
PARLAY_MIN_LEG_EV=0.03
# 讓分 / 獨贏市場混合
H2H_MARKET_BLEND_MLB_FULL=0.4
H2H_MARKET_BLEND_OTHER=0.55
# NPB 有 Yahoo 順位時少貼市場
H2H_MARKET_BLEND_NPB_FULL=0.35
H2H_MIN_EDGE_PCT=1.5
H2H_MIN_CONFIDENCE=0.08
# 初盤最低賠率（避開臭水；與主推統一 ≥1.75）
PREMATCH_MIN_ODDS=1.75
PREMATCH_PRIMARY_MIN_ODDS=1.75
PREMATCH_PRIMARY_MIN_PROB=0.58
FLAT_BET_ALLOW_NPB_TOTALS=true
SPREADS_PLUS15_PRIMARY_PENALTY=0
SPREADS_BLOCK_PLUS15_NO_SCORE=true
# 大小盤模型（市場錨定）
TOTALS_MARKET_BLEND_MLB_FULL=0.6
TOTALS_MARKET_BLEND_MLB=0.65
TOTALS_MIN_EDGE_PCT=2
TOTALS_MIN_CONTRARIAN_EDGE_PCT=5
TOTALS_MIN_LINE_GAP=0.4
TOTALS_MAX_MODEL_MARKET_GAP=1.0
TOTALS_MIN_EV=0.03
TOTALS_PRIMARY_SCORE_PENALTY=15
# 雙軌策略
FLAT_BET_MIN_ODDS=1.80
FLAT_BET_MIN_PROB=0.58
FLAT_BET_ALLOW_MLB_TOTALS=false
FLAT_BET_MIN_EDGE_PCT=2.5
FLAT_BET_MIN_EDGE_PCT_TOTALS=4
FLAT_BET_MIN_EDGE_PCT_PROPS=4
FLAT_BET_PRIMARY_ONLY=true
FLAT_BET_ALLOW_NEGATIVE_SPREADS=false
FLAT_BET_REQUIRE_CONTRARIAN_SUPPORT=true
CONTRARIAN_MIN_WIN_PROB=0.48
CONTRARIAN_MIN_DATA_QUALITY=0.80
CONTRARIAN_MIN_SUPPORT_SIGNALS=2
ACTIONABLE_MAX_EV_BONUS=6
RELIABILITY_MIN_SLICE_SAMPLES=50
PARLAY_ANCHOR_MIN_ODDS=1.55
PARLAY_ANCHOR_MAX_ODDS=1.79
PARLAY_ANCHOR_MIN_PROB=0.58

# 命中率優化（v2）
SPREADS_MIN_COVER_PROB=0.58
SPREADS_MIN_DOG_WIN_PROB=0.47
SPREADS_MAX_MODEL_DEFICIT=0.03
SPREADS_PLUS15_PRIMARY_PENALTY=12
SCORE_MODEL_BLEND_MLB_FULL=0.55
SPREADS_MARKET_BLEND=0.45
PARLAY_SLATE_PRIMARY_ONLY=true
PARLAY_SLATE_MIN_PROB=0.52
PARLAY_SLATE_PLUS15_MIN_PROB=0.58
PARLAY_SLATE_ALLOW_MARKET_FILL=false
TOTALS_MIN_UNDER_GAP=0.5
TOTALS_MIN_UNDER_EDGE_PCT=6
TOTALS_UNDER_MAX_MODEL_EDGE_PCT=0.05
TOTALS_MAX_UNDER_PARK_FACTOR=1.03
